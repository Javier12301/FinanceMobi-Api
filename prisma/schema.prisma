generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum MovementType {
  INCOME
  EXPENSE
  TRANSFER
}

enum DelegationRole {
  SUPERVISOR
  ASESOR
}

enum Frequency {
  MONTHLY
}

// ──────────────────────────────────────────
// Users & Delegation
// ──────────────────────────────────────────

model User {
  id                          String   @id @default(uuid())
  email                       String   @unique
  name                        String
  passwordHash                String?
  googleId                    String?  @unique
  encryptedGoogleRefreshToken String?  @db.Text
  driveFolderId               String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  ownedWallets         Wallet[]             @relation("WalletOwner")
  categories           Category[]
  budgets              Budget[]
  recurringRules       RecurringRule[]
  delegationsGiven     UserDelegation[]     @relation("DelegationOwner")
  delegationsReceived  UserDelegation[]     @relation("DelegationDelegated")
  transactionHistories     TransactionHistory[]
  debts                    Debt[]
  notificationDevices      NotificationDevice[]
  notificationPreference   NotificationPreference?
}

model UserDelegation {
  id              String         @id @default(uuid())
  ownerId         String
  delegatedUserId String
  role            DelegationRole
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  owner     User @relation("DelegationOwner", fields: [ownerId], references: [id])
  delegated User @relation("DelegationDelegated", fields: [delegatedUserId], references: [id])

  @@unique([ownerId, delegatedUserId])
}

// ──────────────────────────────────────────
// Wallets
// ──────────────────────────────────────────

model WalletType {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  wallets Wallet[]
}

model Wallet {
  id             String     @id @default(uuid())
  ownerId        String
  typeId         Int
  name           String
  description    String?
  initialBalance Decimal    @db.Decimal(15, 2)
  currentBalance Decimal    @db.Decimal(15, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  owner                  User          @relation("WalletOwner", fields: [ownerId], references: [id])
  type                   WalletType    @relation(fields: [typeId], references: [id])
  transactions           Transaction[] @relation("SourceWallet")
  incomingTransfers      Transaction[] @relation("DestinationWallet")
  recurringRules         RecurringRule[] @relation("RuleSourceWallet")
  incomingRecurringRules RecurringRule[] @relation("RuleDestinationWallet")
}

// ──────────────────────────────────────────
// Categories
// ──────────────────────────────────────────

model Category {
  id           String       @id @default(uuid())
  ownerId      String
  movementType MovementType
  name         String
  icon         String?
  color        String?
  createdAt    DateTime     @default(now())

  owner          User          @relation(fields: [ownerId], references: [id])
  transactions   Transaction[]
  budgets        Budget[]
  recurringRules RecurringRule[]
  debts          Debt[]
}

// ──────────────────────────────────────────
// Budgets
// ──────────────────────────────────────────

model Budget {
  id         String   @id @default(uuid())
  ownerId    String
  categoryId String
  month      String   // formato "YYYY-MM"
  limit      Decimal  @db.Decimal(15, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner    User     @relation(fields: [ownerId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([ownerId, categoryId, month])
}

// ──────────────────────────────────────────
// Transactions & Audit
// ──────────────────────────────────────────

model Transaction {
  id                  String       @id @default(uuid())
  walletId            String
  destinationWalletId String?
  categoryId          String
  amount              Decimal      @db.Decimal(15, 2)
  description         String?
  date                DateTime
  movementType        MovementType
  debtId              String?
  deletedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  wallet            Wallet                  @relation("SourceWallet", fields: [walletId], references: [id])
  destinationWallet Wallet?                 @relation("DestinationWallet", fields: [destinationWalletId], references: [id])
  category          Category                @relation(fields: [categoryId], references: [id])
  debt              Debt?                   @relation("DebtTransactions", fields: [debtId], references: [id])
  history           TransactionHistory[]
  attachments       TransactionAttachment[]
}

model TransactionHistory {
  id            String   @id @default(uuid())
  transactionId String
  modifiedById  String
  action        String
  oldSnapshot   Json?
  newSnapshot   Json
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
  modifiedBy  User        @relation(fields: [modifiedById], references: [id])
}

model TransactionAttachment {
  id            String   @id @default(uuid())
  transactionId String
  googleFileId  String   @unique
  mimeType      String
  uploadedAt    DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
}

// ──────────────────────────────────────────
// Recurring Rules
// ──────────────────────────────────────────

// ──────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────

model NotificationDevice {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, token])
}

model NotificationPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  dailyReminder   Boolean  @default(true)
  budgetAlerts    Boolean  @default(true)
  recurringAlerts Boolean  @default(true)
  reminderHour    String   @default("21:00")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ──────────────────────────────────────────
// Debts & Loans
// ──────────────────────────────────────────

model Debt {
  id                String    @id @default(uuid())
  ownerId           String
  direction         String    // I_OWE | OWED_TO_ME
  counterparty      String
  categoryId        String?
  principal         Decimal   @db.Decimal(15, 2)
  remaining         Decimal   @db.Decimal(15, 2)
  recurringRuleId   String?
  installmentsTotal Int?
  installmentsPaid  Int       @default(0)
  dueDate           DateTime?
  status            String    @default("ACTIVE") // ACTIVE | PAID
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  owner          User            @relation(fields: [ownerId], references: [id])
  category       Category?       @relation(fields: [categoryId], references: [id])
  transactions   Transaction[]   @relation("DebtTransactions")
  recurringRules RecurringRule[]

  @@index([ownerId])
}

model RecurringRule {
  id                  String       @id @default(uuid())
  ownerId             String
  walletId            String
  destinationWalletId String?
  categoryId          String
  movementType        MovementType
  amount              Decimal      @db.Decimal(15, 2)
  description         String?
  dayOfMonth          Int
  frequency           Frequency    @default(MONTHLY)
  autoPost            Boolean      @default(false)
  startDate           DateTime
  endDate             DateTime?
  nextRunDate         DateTime
  active              Boolean      @default(true)
  debtId              String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  owner             User     @relation(fields: [ownerId], references: [id])
  wallet            Wallet   @relation("RuleSourceWallet", fields: [walletId], references: [id])
  destinationWallet Wallet?  @relation("RuleDestinationWallet", fields: [destinationWalletId], references: [id])
  category          Category @relation(fields: [categoryId], references: [id])
  debt              Debt?    @relation(fields: [debtId], references: [id])
}
