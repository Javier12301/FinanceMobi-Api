meta {
  name: Delete Attachment
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/api/transactions/{{transactionId}}/attachments/{{attachmentId}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-Owner-Id: {{ownerContextId}}
}

docs {
  Borra el archivo de Google Drive primero, luego la fila en DB.
  Si Drive falla, retorna error y la DB queda sin cambios.
  Respuesta exitosa: 204 sin cuerpo.
}
