meta {
  name: Create Category
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/categories
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-Owner-Id: {{ownerContextId}}
}

body:json {
  {
    "name": "Alimentación",
    "movementType": "EXPENSE"
  }
}

script:post-response {
  if (res.body && res.body.id) {
    bru.setVar("categoryId", res.body.id);
  }
}
