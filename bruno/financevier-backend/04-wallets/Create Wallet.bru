meta {
  name: Create Wallet
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/wallets
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-Owner-Id: {{ownerContextId}}
}

body:json {
  {
    "name": "Macro",
    "typeId": 1,
    "description": "Main cash wallet",
    "initialBalance": 2000
  }
}

script:post-response {
  if (res.body && res.body.id) {
    bru.setVar("walletId", res.body.id);
  }
}
