meta {
  name: Update Wallet
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/api/wallets/{{walletId}}
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-Owner-Id: {{ownerContextId}}
}

body:json {
  {
    "name": "Cash Updated",
    "description": "Updated wallet metadata"
  }
}
