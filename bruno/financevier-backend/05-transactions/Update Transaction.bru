meta {
  name: Update Transaction
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/api/transactions/{{transactionId}}
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-Owner-Id: {{ownerContextId}}
}

body:json {
  {
    "amount": "30.00",
    "description": "Updated transaction sample"
  }
}
