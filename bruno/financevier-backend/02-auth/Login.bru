meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "user@example.com",
    "password": "change-me"
  }
}

script:post-response {
  if (res.body && res.body.token) {
    bru.setVar("token", res.body.token);
  }
}
