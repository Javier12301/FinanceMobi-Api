meta {
  name: Google Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/google
  body: json
  auth: none
}

headers {
  X-Owner-Id: {{ownerContextId}}
}

body:json {
  {
    "idToken": "eyJhbGciOiJSUzI1NiIsImtpZCI6ImQxMjk3OGJhNGMyOWVmMTE1NGEzNGU0ODcwYzdhM2E1MWQyNmRmMTAiLCJ0eXAiOiJKV1QifQ..VfpiKM8W2N0bGjFz6hKzrHIwyjv9Hniwx6lrcDFqIZrli5nJfmyUi1B5bgVTj4xbJkWdlh-S4tS9VooV7v4xovPfqhPMtBe8Bzr7aeV7S8JzePDmeixvwk3C1yGXYY-wK24sqYNjRNJytzQ9Bf4wXfiKc7kteWGZsAYrK012v9R5MeNZ5jZ09Sz_wqfCYIUbYg_-7LESqsw0pdtm3U130SB4SWtHAXVtoqHRDrEaqqmo5aWH9xFk7n6on_9g6LSCU7XlqF28l6B3za9HVLhX6zLLYvvHTk5n0jmOIMBCrxkHIYc1icEKkudHSH5uHUtaFELIYDnu2-n_FyKBIs_Hng"
  }
}

script:post-response {
  if (res.body && res.body.token) {
    bru.setVar("token", res.body.token);
    // Decodifica sub del JWT para usar como X-Owner-Id
    const parts = res.body.token.split('.');
    const payload = JSON.parse(atob(parts[1]));
    bru.setVar("ownerContextId", payload.sub);
  }
}
